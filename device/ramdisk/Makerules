# This Makefile contains rules to build files in the device/ramdisk/ directory.

# Name of this component (the directory this file is stored in)
COMP = device/ramdisk

# Source files for this component
C_FILES = ramdiskInit.c ramdiskOpen.c ramdiskClose.c ramdiskRead.c \
          ramdiskWrite.c ramdiskSeek.c ramdiskControl.c
S_FILES =

# Add the files to the compile source path
DIR = ${TOPDIR}/${COMP}
COMP_SRC += ${S_FILES:%=${DIR}/%} ${C_FILES:%=${DIR}/%}
